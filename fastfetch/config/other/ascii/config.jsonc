            "keyColor": "38;2;124;134;166"
        },
        {
            "type": "custom",
            "format": "│ └──╮",
            "outputColor": "38;2;124;134;166"
        },
        {
            "type": "custom",
            "format": "└────╯",
            "outputColor": "38;2;124;134;166"
        },
        {
            "type": "break",
            "key": ""
